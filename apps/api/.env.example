# ===========================================
# RDAM API — Variables de Entorno
# ===========================================

# Base de datos PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/rdam_db?schema=public"
DB_SYNCHRONIZE="false"

# Redis (OTP sessions + cache)
REDIS_URL="redis://localhost:6379"

# JWT — Autenticación interna (Operario/Supervisor)
JWT_SECRET="cambiar-en-produccion-min-32-caracteres"
JWT_EXPIRES_IN="8h"
JWT_REFRESH_EXPIRES_IN="24h"

# JWT — Sesión OTP ciudadano
OTP_JWT_SECRET="cambiar-otp-secret-min-32-caracteres"
OTP_JWT_EXPIRES_IN="30m"

# OTP Config
OTP_TTL_SECONDS=600
OTP_MAX_INTENTOS=3

# Encriptación AES-256-GCM (clave hex de 32 bytes = 64 chars hex)
ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# Blind index salt para búsqueda de DNI
DNI_HASH_SALT="cambiar-salt-produccion"

# S3 / MinIO — Almacenamiento de PDFs
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="rdam-documents"
S3_REGION="us-east-1"

# Email (Nodemailer SMTP)
EMAIL_HOST="smtp.example.com"
EMAIL_PORT=587
EMAIL_USER="user@example.com"
EMAIL_PASS="password"
EMAIL_FROM="noreply@rdam.justiciasantafe.gov.ar"

# Pasarela de Pago
PASARELA_API_URL="https://pasarela.proveedor.com"
PASARELA_API_KEY="pk_test_xxx"
PASARELA_WEBHOOK_SECRET="whsec_xxx"

# App
PORT=3000
NODE_ENV="development"
FRONTEND_URL="http://localhost:3002"

# SLA
SLA_WARNING_HOURS=30
SLA_CRITICAL_HOURS=48

# Cron Jobs
CRON_SCHEDULE_VENCIMIENTOS="0 0 * * *"
CRON_DIAS_PENDIENTE_PAGO=60
CRON_DIAS_CERTIFICADO=90
