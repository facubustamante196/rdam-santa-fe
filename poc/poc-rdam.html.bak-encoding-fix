    }

    // ===== INIT =====
    // Start on portal home
    showPortalView('home');

    // ===== OTP STATE =====
    let otpVerified = false;
    let otpDNIValue = '';
    let otpEmailValue = '';
    let otpAttempts = 3;
    let timerInterval = null;

    // ===== OTP FUNCTIONS =====
    function solicitarCodigo() {
      const dni = document.getElementById('otpDNI').value.trim();
      const email = document.getElementById('otpEmail').value.trim();
      if (!dni || !email) {
        showToast('IngresÃ¡ tu DNI y email para continuar', 'error');
        return;
      }
      otpDNIValue = dni;
      otpEmailValue = email;

      const btn = document.getElementById('btnSolicitarCodigo');
      btn.disabled = true;
      btn.innerHTML = 'â³ Enviando...';

      setTimeout(() => {
        btn.disabled = false;
        btn.innerHTML = 'ðŸ“§ Enviar cÃ³digo al email';

        // Mostrar email en la pantalla de verificaciÃ³n
        const display = document.getElementById('otpEmailDisplay');
        if (display) display.textContent = otpEmailValue;

        showPortalView('otp-verificacion');
        startOtpTimer();
        showToast('âœ‰ï¸ CÃ³digo enviado a ' + otpEmailValue, 'success');
      }, 1200);
    }

    function startOtpTimer() {
      let seconds = 600;
      const el = document.getElementById('otpTimer');
      clearInterval(timerInterval);
      timerInterval = setInterval(() => {
        seconds--;
        const m = String(Math.floor(seconds / 60)).padStart(2, '0');
        const s = String(seconds % 60).padStart(2, '0');
        if (el) el.textContent = m + ':' + s;
        if (seconds <= 0) clearInterval(timerInterval);
      }, 1000);
    }

    function verificarCodigo() {
      const digits = Array.from(document.querySelectorAll('.otp-digit')).map(d => d.value).join('');
      if (digits.length < 6) {
        showToast('IngresÃ¡ los 6 dÃ­gitos del cÃ³digo', 'error');
        return;
      }
      // En POC cualquier cÃ³digo de 6 dÃ­gitos funciona
      clearInterval(timerInterval);
      otpVerified = true;

      // Pre-llenar y bloquear el DNI en el formulario
      const dniInput = document.getElementById('dniInput');
      if (dniInput) {
        dniInput.value = otpDNIValue;
        dniInput.setAttribute('readonly', 'readonly');
        dniInput.style.background = 'var(--neutral-100)';
        dniInput.style.color = 'var(--neutral-500)';
      }

      // Mostrar banner de verificado
      const banner = document.getElementById('otpVerifiedBanner');
      if (banner) banner.style.display = 'flex';

      showPortalView('formulario');
      window.scrollTo(0, 0);
      showToast('âœ… Identidad verificada. CompletÃ¡ tu solicitud.', 'success');
    }
    function reenviarCodigo() {
      otpAttempts = 3;
      document.querySelectorAll('.otp-digit').forEach(d => { d.value = ''; d.classList.remove('filled'); });
      const el = document.getElementById('otpAttemptsLeft');
      if (el) el.textContent = '3';
      startOtpTimer();
      showToast('ðŸ“§ Nuevo cÃ³digo enviado a ' + otpEmailValue, 'info');
    }

    function otpKeyUp(input, idx) {
      if (input.value.length === 1) {
        const next = document.querySelector(`.otp-digit[data-idx="${idx + 1}"]`);
        if (next) next.focus();
      }
      if (input.value.length === 0 && idx > 0) {
        const prev = document.querySelector(`.otp-digit[data-idx="${idx - 1}"]`);
        if (prev) prev.focus();
      }
    }

    // ===== PAGO CONECTADO AL BACKOFFICE =====
    function procesarPago() {
      const btn = document.querySelector('#portal-pago .btn-primary');
      if (!btn) return;
      const orig = btn.innerHTML;
      btn.disabled = true;
      btn.innerHTML = '<span class="loading-spinner"></span> Procesando pago...';

      setTimeout(() => {
        btn.innerHTML = orig;
        btn.disabled = false;

        // Mostrar confirmaciÃ³n en el portal
        showPortalView('confirmacion');
        window.scrollTo(0, 0);
        showToast('âœ… Pago confirmado exitosamente', 'success');

        // Simular webhook: actualizar backoffice
        setTimeout(() => updateBackofficeAfterPayment(), 500);
      }, 2000);
    }

    function updateBackofficeAfterPayment() {
      // Buscar la fila de la nueva solicitud (RDAM-2025-00248) y actualizarla a PAGADA
      // Si no existe, agregar una fila nueva al inicio de la tabla
      const tbody = document.querySelector('#view-lista tbody');
      if (!tbody) return;

      // Verificar si ya existe la fila
      let existingRow = null;
      tbody.querySelectorAll('tr').forEach(row => {
        const idCell = row.querySelector('.id-cell');
        if (idCell && idCell.textContent.includes('00248')) existingRow = row;
      });

      if (existingRow) {
        // Actualizar estado a Pagada
        const badgeCell = existingRow.querySelector('td:nth-child(5)');
        const actionCell = existingRow.querySelector('td:last-child');
        if (badgeCell) badgeCell.innerHTML = '<span class="status-badge badge-pagada">Pagada</span>';
        if (actionCell) actionCell.innerHTML = `
          <div style="display:flex;gap:6px;">
            <button class="action-btn primary" onclick="showView('detalle')">Ver</button>
            <button class="action-btn primary" style="background:var(--success);color:white;" onclick="showView('carga')">Cargar PDF</button>
          </div>`;
      } else {
        // Agregar la nueva fila al principio de la tabla
        const newRow = document.createElement('tr');
        newRow.style.animation = 'fadeIn 0.4s ease';
        newRow.style.background = 'rgba(5,150,105,0.05)';
        newRow.innerHTML = `
          <td><input type="checkbox"></td>
          <td class="id-cell" style="color:var(--success);font-weight:700;">RDAM-2025-00248</td>
          <td>
            <div class="name-cell">${otpVerified ? otpDNIValue + ' Â· ' : ''}GarcÃ­a LÃ³pez, Carlos M.</div>
            <div style="font-size:11px;color:var(--neutral-400);">${otpVerified ? otpEmailValue : 'nuevo.solicitante@email.com'}</div>
          </td>
          <td>Santa Fe</td>
          <td><span class="status-badge badge-pagada">Pagada</span> <span style="font-size:10px;color:var(--success);font-weight:600;">âš¡ NUEVO</span></td>
          <td class="date-cell">Ahora mismo</td>
          <td style="font-size:12px;">Sin asignar</td>
          <td>
            <div style="display:flex;gap:6px;">
              <button class="action-btn primary" onclick="showView('detalle')">Ver</button>
              <button class="action-btn primary" style="background:var(--success);color:white;" onclick="showView('carga')">Cargar PDF</button>
            </div>
          </td>`;
        tbody.insertBefore(newRow, tbody.firstChild);
      }
    }

    // ===== FORZAR ESTADO (Supervisor) =====
    function forzarEstado() {
      const estado = document.getElementById('estadoDestino').value;
      const motivo = document.getElementById('motivoForzado').value.trim();
      if (!estado) { showToast('SeleccionÃ¡ un estado de destino', 'error'); return; }
      if (!motivo) { showToast('El motivo es obligatorio', 'error'); return; }
      closeModal('forzarEstadoModal');
      showToast(`âš¡ Estado forzado a "${estado}". Registrado en auditorÃ­a.`, 'info');
      document.getElementById('motivoForzado').value = '';
      document.getElementById('estadoDestino').value = '';
    }

  </script>
